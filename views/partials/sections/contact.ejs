      <div class="form-row">
        <div class="form-group">
          <label>Prénom & Nom *</label>
          <input type="text" id="f-name" placeholder="Jean Dupont" />
        </div>
        <div class="form-group">
          <label>Téléphone *</label>
          <input type="tel" id="f-tel" placeholder="07 89 84 74 39" />
        </div>
      </div>

      <div class="form-group">
        <label>E-mail</label>
        <input type="email" id="f-email" placeholder="votre@email.fr" />
      </div>

      <div class="form-group">
        <label>Type de travaux</label>
        <select id="f-type">
          <option value="">— Sélectionnez une prestation —</option>
          <option>Maçonnerie générale</option>
          <option>Rénovation</option>
          <option>Extension / Agrandissement</option>
          <option>Escalier / Muret / Terrasse</option>
          <option>Petits travaux</option>
          <option>Autre / Je ne sais pas encore</option>
        </select>
      </div>

      <div class="form-group">
        <label>Votre message *</label>
        <textarea id="f-msg" placeholder="Décrivez votre projet : localisation, nature des travaux, délais souhaités..."></textarea>
      </div>

      <button type="button" class="form-submit" onclick="submitForm()">Envoyer ma demande de devis →</button>
