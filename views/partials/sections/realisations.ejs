<!-- RÉALISATIONS -->
<section id="realisations">
  <div class="realisations-header">
    <div class="section-eyebrow">Portfolio</div>
    <h2 class="section-title">Nos <span>réalisations</span></h2>
    <p class="section-text">Cliquez sur une photo pour l'agrandir. Chaque projet est unique, réalisé avec le même souci du détail.</p>
    <div class="gallery-filters">
      <button class="gallery-filter active" onclick="filterGallery('all', this)">Tous</button>
      <button class="gallery-filter" onclick="filterGallery('extension', this)">Extensions</button>
      <button class="gallery-filter" onclick="filterGallery('renovation', this)">Rénovation</button>
      <button class="gallery-filter" onclick="filterGallery('amenagement', this)">Aménagements</button>
    </div>
  </div>

  <div class="gallery-grid" id="gallery"></div>

  <div class="gallery-cta">
    <p style="color:var(--text-light);font-size:14px;margin-bottom:16px;">Plus de photos disponibles sur notre page Facebook</p>
    <a href="https://fr-fr.facebook.com/jean.m.douay" target="_blank" rel="noopener" class="social-link" style="display:inline-flex;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      Voir toutes nos réalisations sur Facebook
    </a>
  </div>
</section>

<!-- LIGHTBOX -->
<div id="lightbox">
  <div class="lightbox-inner">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <button class="lightbox-nav lightbox-prev" onclick="prevLightbox()">‹</button>
    <button class="lightbox-nav lightbox-next" onclick="nextLightbox()">›</button>
    <div class="lightbox-img-area">
      <div class="lightbox-brick-bg" id="lb-bg"></div>
      <div class="lightbox-placeholder-txt">
        <div style="font-size:2rem;margin-bottom:8px;">🏗️</div>
        <div>Photo du chantier</div>
        <div style="font-size:11px;margin-top:4px;opacity:0.6;">À remplacer par vos vraies photos</div>
      </div>
    </div>
    <div class="lightbox-info">
      <div class="lightbox-category" id="lb-cat">Extension</div>
      <h3 class="lightbox-title" id="lb-title">Titre du projet</h3>
      <p class="lightbox-desc" id="lb-desc">Description du projet.</p>
    </div>
  </div>
</div>

<!-- CARTE / ZONE D'INTERVENTION -->
<section id="carte">
  <div class="carte-grid">
    <div>
      <div class="section-eyebrow">Zone d'intervention</div>
      <h2 class="section-title">Je me déplace dans <span>toute la Somme</span></h2>
      <p class="section-text">Basé à Villers-Bocage (80260), j'interviens dans un rayon d'environ 50 km pour tous types de chantiers.</p>

      <div class="zone-list">
        <div class="zone-row">
          <div class="zone-row-icon">📍</div>
          <div class="zone-row-label"><strong>Villers-Bocage</strong> — Siège</div>
          <div class="zone-row-dist">Base</div>
        </div>
        <div class="zone-row">
          <div class="zone-row-icon">🏙️</div>
          <div class="zone-row-label">Amiens</div>
          <div class="zone-row-dist">~13 km</div>
        </div>
        <div class="zone-row">
          <div class="zone-row-icon">🏙️</div>
          <div class="zone-row-label">Doullens</div>
          <div class="zone-row-dist">~20 km</div>
        </div>
        <div class="zone-row">
          <div class="zone-row-icon">🏙️</div>
          <div class="zone-row-label">Corbie</div>
          <div class="zone-row-dist">~17 km</div>
        </div>
        <div class="zone-row">
          <div class="zone-row-icon">🏙️</div>
          <div class="zone-row-label">Albert</div>
          <div class="zone-row-dist">~24 km</div>
        </div>
        <div class="zone-row">
          <div class="zone-row-icon">🗺️</div>
          <div class="zone-row-label">Somme (80) et alentours</div>
          <div class="zone-row-dist">rayon ~40 km</div>
        </div>
      </div>

      <div style="margin-top:28px;">
        <a href="/contact" class="btn-primary">Je suis dans votre secteur – Devis gratuit</a>
      </div>
    </div>

    <div>
      <div class="map-wrap" id="map-wrap">
        <!-- La carte Google Maps sera chargée après consentement RGPD -->
        <div id="map-placeholder" style="width:100%;height:100%;background:var(--cream);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;">
          <div style="font-size:3rem;">🗺️</div>
          <div style="font-size:15px;font-weight:600;color:var(--charcoal);">Carte Google Maps</div>
          <div style="font-size:13px;color:var(--text-light);text-align:center;padding:0 20px;">Acceptez les cookies pour afficher la carte interactive de notre zone d'intervention.</div>
          <button onclick="acceptRGPD()" style="background:var(--brick);color:white;border:none;padding:10px 22px;border-radius:3px;font-family:'Raleway',sans-serif;font-size:13px;font-weight:700;cursor:pointer;margin-top:8px;">Afficher la carte</button>
        </div>
      </div>
    </div>
  </div>
</section>

