<!-- HERO -->
<section id="accueil">
  <div class="hero-bg-pattern"></div>
  <div class="hero-accent"></div>
  <div class="hero-content">
    <div class="hero-badge">🧱 Artisan qualifié · Villers-Bocage (80260)</div>
    <h1 class="hero-title">JMD</h1>
    <p class="hero-subtitle">Bâtissons ensemble vos projets</p>
    <p class="hero-text">
      Fort de plusieurs années d'expérience, Jean-Michel Douay vous accompagne pour tous vos projets de maçonnerie générale, rénovation et agrandissements dans la Somme.
    </p>
    <div class="hero-buttons">
      <a href="/contact" class="btn-primary">Demandez un devis gratuit</a>
      <a href="/prestations" class="btn-outline">Nos prestations</a>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-number">35</div>
        <div class="stat-label">Ans d'expérience</div>
      </div>
      <div class="stat">
        <div class="stat-number">5★</div>
        <div class="stat-label">Note clients</div>
      </div>
      <div class="stat">
        <div class="stat-number">80</div>
        <div class="stat-label">Dép. Somme</div>
      </div>
    </div>
  </div>
  <div class="hero-carousel" id="hero-carousel" aria-label="Carrousel de réalisations">
    <div class="hero-carousel-track">
      <article class="hero-slide active">
        <img src="photos/hero-1.jpg" alt="Réalisation extension de maison" onerror="this.onerror=null;this.src='/images/logo_jean_michel_douay_300dpi.png';" />
        <div class="hero-slide-caption">Extension de maison · Villers-Bocage</div>
      </article>
      <article class="hero-slide">
        <img src="photos/hero-2.jpg" alt="Réalisation rénovation de façade" onerror="this.onerror=null;this.src='/images/logo_jean_michel_douay_300dpi.png';" />
        <div class="hero-slide-caption">Rénovation façade · Somme</div>
      </article>
      <article class="hero-slide">
        <img src="photos/hero-3.jpg" alt="Réalisation terrasse béton" onerror="this.onerror=null;this.src='/images/logo_jean_michel_douay_300dpi.png';" />
        <div class="hero-slide-caption">Terrasse béton · Amiens</div>
      </article>
    </div>
    <div class="hero-carousel-dots" id="hero-carousel-dots"></div>
    <div class="hero-carousel-controls">
      <button class="hero-carousel-btn" id="hero-prev" aria-label="Photo précédente">‹</button>
      <button class="hero-carousel-btn" id="hero-next" aria-label="Photo suivante">›</button>
    </div>
  </div>
</section>

<!-- COMPTEURS ANIMÉS -->
<section id="counters">
  <div class="counters-grid">
    <div class="counter-item">
      <div class="counter-value">
        <span class="counter-num" data-target="35" data-suffix="">0</span><span class="counter-suffix"></span>
      </div>
      <div class="counter-label">Années d'expérience</div>
    </div>
    <div class="counter-item">
      <div class="counter-value">
        <span class="counter-num" data-target="150" data-suffix="+">0</span><span class="counter-suffix">+</span>
      </div>
      <div class="counter-label">Chantiers réalisés</div>
    </div>
    <div class="counter-item">
      <div class="counter-value">
        <span class="counter-num" data-target="98" data-suffix="%">0</span><span class="counter-suffix">%</span>
      </div>
      <div class="counter-label">Clients satisfaits</div>
    </div>
    <div class="counter-item">
      <div class="counter-value">
        <span class="counter-num" data-target="5" data-suffix="">0</span><span class="counter-suffix"> ★</span>
      </div>
      <div class="counter-label">Note moyenne</div>
    </div>
  </div>
</section>
