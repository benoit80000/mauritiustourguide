<!-- LIGHTBOX -->
<div id="lightbox">
  <div class="lightbox-inner">
    <button class="lightbox-close" onclick="closeLightbox()">✕</button>
    <button class="lightbox-nav lightbox-prev" onclick="prevLightbox()">‹</button>
    <button class="lightbox-nav lightbox-next" onclick="nextLightbox()">›</button>
    <div class="lightbox-img-area">
      <div class="lightbox-brick-bg" id="lb-bg"></div>
      <div class="lightbox-placeholder-txt">
        <div style="font-size:2rem;margin-bottom:8px;">🏗️</div>
        <div>Photo du chantier</div>
        <div style="font-size:11px;margin-top:4px;opacity:0.6;">À remplacer par vos vraies photos</div>
      </div>
    </div>
    <div class="lightbox-info">
      <div class="lightbox-category" id="lb-cat">Extension</div>
      <h3 class="lightbox-title" id="lb-title">Titre du projet</h3>
      <p class="lightbox-desc" id="lb-desc">Description du projet.</p>
    </div>
  </div>
</div>

<!-- CARTE / ZONE D'INTERVENTION -->
